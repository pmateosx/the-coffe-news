# Turso (en dev puede omitirse: se usa file:local.db)
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=

# Vercel Blob (imágenes de portada)
BLOB_READ_WRITE_TOKEN=

# Firma de la cookie de sesión (openssl rand -hex 32)
SESSION_SECRET=

# Protege /api/cron/rollover (openssl rand -hex 32)
CRON_SECRET=
